<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="PetStore API Test Suite"
       verbose="1"
       parallel="classes"
       thread-count="3">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Pet Endpoint Tests">
        <classes>
            <class name="com.aitesting.api.petstore.PetTests"/>
        </classes>
    </test>

    <test name="Store Endpoint Tests">
        <classes>
            <class name="com.aitesting.api.petstore.StoreTests"/>
        </classes>
    </test>

    <test name="User Endpoint Tests">
        <classes>
            <class name="com.aitesting.api.petstore.UserTests"/>
        </classes>
    </test>

    <!--
        Insurance suite — runs against a mock or staging environment.
        Set BASE_URL env var to your insurance API before running:
          BASE_URL=https://insurance-staging.mycompany.com mvn test -pl api -am
    -->
    <test name="Insurance Quote Tests">
        <classes>
            <class name="com.aitesting.api.insurance.QuoteTests"/>
        </classes>
    </test>

    <test name="Insurance Policy Tests">
        <classes>
            <class name="com.aitesting.api.insurance.PolicyTests"/>
        </classes>
    </test>

</suite>
